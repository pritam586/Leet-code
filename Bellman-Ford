class Solution {
  public:
    vector<int> bellmanFord(int V, vector<vector<int>>& edges, int src) {
        // Code here
        const int INF = 100000000;
        vector<int> dist(V, INF);
        dist[src] = 0;
        // Relax all edges V-1 times
        for (int i = 0; i < V - 1; i++) {
            bool updated = false;
            
            for (auto &e : edges) {
                int u = e[0];
                int v = e[1];
                int w = e[2];
                
                if (dist[u] != INF && dist[u] + w < dist[v]) {
                    dist[v] = dist[u] + w;
                    updated = true;
                }
            }
            
            // if no update happens, stop early
            if (!updated) break;
        }
// negative cycle
        for (auto &e : edges) {
            int u = e[0];
            int v = e[1];
            int w = e[2];
            
            if (dist[u] != INF && dist[u] + w < dist[v]) {
                return {-1};
            }
        }
        return dist;
    }
};
